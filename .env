# =============================================
# Eventos Elite — Variables de entorno backend
# Copia este archivo como .env y completa los valores
# =============================================

# MongoDB
MONGO_URI=mongodb://localhost:27017/eventos_elite

# JWT
JWT_SECRET=eventoselite_super_secret_key

# Puerto del servidor (opcional, default 5000)
PORT=5000

# Entorno
NODE_ENV=development


CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Credenciales del administrador inicial (para el seed)
ADMIN_EMAIL=admin@eventoselit.com
ADMIN_PASSWORD=Admin123!
